# ── Required ──────────────────────────────────────────────────────────────────

# Local base directory — all subdirectories become target folder buttons in the UI
MUSIK_DIR=/musik

# Path to the yt-dlp binary (defaults to ~/yt-dlp_linux if not set)
YTDLP_BIN=/home/youruser/yt-dlp_linux


# ── hifi-api (Tidal) ──────────────────────────────────────────────────────────
# Comma-separated list of hifi-api instance URLs.
# If not set, the built-in public pool of 8 servers is used.
# For reliable downloads, run your own instance (see README).
# HIFI_API_URL=http://localhost:8000,https://api.monochrome.tf


# ── Download History ──────────────────────────────────────────────────────────
# Path to the JSON file where download history is stored.
# Defaults to one level above MUSIK_DIR.
# HISTORY_FILE=/ssd-daten/download_history.json


# ── Nextcloud Sync (optional) ─────────────────────────────────────────────────
# Set NEXTCLOUD_ENABLED=true to sync after every download.
# All NEXTCLOUD_* variables below are required if enabled.

NEXTCLOUD_ENABLED=false
NEXTCLOUD_USER=your_username
NEXTCLOUD_PASSWORD=your_app_password
NEXTCLOUD_URL=https://your-nextcloud.example.com/nextcloud
NEXTCLOUD_MUSIK_PATH=/Musik
